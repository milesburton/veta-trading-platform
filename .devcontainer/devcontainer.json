{
  "name": "Equities Trading Simulator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "workspaceFolder": "/workspaces/virtual-equities-trading-application",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/virtual-equities-trading-application,type=bind,consistency=cached",
  "forwardPorts": [
    8080, 3000, 9090, 3100, 5000, 5001, 5002, 5003, 5004, 5005, 5006, 5007,
    5008, 5009, 5011, 5013, 5014, 5015, 5017, 5018, 5021, 5022, 5023, 5024,
    9879, 9881
  ],
  "portsAttributes": {
    "8080": {
      "label": "Frontend UI",
      "onAutoForward": "notify",
      "protocol": "http",
      "elevateIfNeeded": false
    },
    "3000": {
      "label": "Grafana",
      "onAutoForward": "notify",
      "protocol": "http"
    },
    "9090": { "label": "Prometheus", "onAutoForward": "ignore" },
    "3100": { "label": "Loki", "onAutoForward": "ignore" },
    "5000": { "label": "Market Sim", "onAutoForward": "ignore" },
    "5001": { "label": "EMS", "onAutoForward": "ignore" },
    "5002": { "label": "OMS", "onAutoForward": "ignore" },
    "5003": { "label": "Limit Algo", "onAutoForward": "ignore" },
    "5004": { "label": "TWAP Algo", "onAutoForward": "ignore" },
    "5005": { "label": "POV Algo", "onAutoForward": "ignore" },
    "5006": { "label": "VWAP Algo", "onAutoForward": "ignore" },
    "5007": { "label": "Observability", "onAutoForward": "ignore" },
    "5008": { "label": "User Service", "onAutoForward": "ignore" },
    "5009": { "label": "Journal", "onAutoForward": "ignore" },
    "5011": { "label": "Gateway (BFF)", "onAutoForward": "ignore" },
    "5013": { "label": "News Aggregator", "onAutoForward": "ignore" },
    "5014": { "label": "Analytics", "onAutoForward": "ignore" },
    "5015": { "label": "Market Data Service", "onAutoForward": "ignore" },
    "5017": { "label": "Feature Engine", "onAutoForward": "ignore" },
    "5018": { "label": "Signal Engine", "onAutoForward": "ignore" },
    "5021": { "label": "Iceberg Algo", "onAutoForward": "ignore" },
    "5022": { "label": "Sniper Algo", "onAutoForward": "ignore" },
    "5023": { "label": "Arrival Price Algo", "onAutoForward": "ignore" },
    "5024": { "label": "LLM Advisory", "onAutoForward": "ignore" },
    "9879": { "label": "FIX Exchange (health)", "onAutoForward": "ignore" },
    "9881": { "label": "FIX Gateway (WS)", "onAutoForward": "ignore" }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "deno.path": "/home/deno/.deno/bin/deno",
        "security.workspace.trust.startupPrompt": "never",
        "extensions.autoUpdate": true,
        "extensions.autoCheckUpdates": true
      },
      "extensions": [
        "GitHub.copilot-chat",
        "openai.chatgpt",
        "anthropic.claude-code",
        "denoland.vscode-deno",
        "foxundermoon.shell-format",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "skyapps.fish-vscode",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        "charliermarsh.ruff",
        "ms-playwright.playwright",
        "rangav.vscode-thunder-client",
        "humao.rest-client",
        "yoavbls.pretty-ts-errors",
        "usernamehw.errorlens"
      ]
    }
  },
  "initializeCommand": "mkdir -p $HOME/.ssh $HOME/.config/gh $HOME/.claude $HOME/.fly && touch $HOME/.gitconfig",
  "remoteUser": "deno",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/deno/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gh,target=/home/deno/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/deno/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/deno/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.fly,target=/home/deno/.fly,type=bind,consistency=cached"
  ],
  "postCreateCommand": "cd ${containerWorkspaceFolder}/frontend && npm ci --ignore-scripts && cd ${containerWorkspaceFolder} && ./frontend/node_modules/.bin/husky install .husky",
  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-start.sh"
}

#!/bin/sh

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
COMMIT_SHA=$(git rev-parse --short HEAD)

if [ -f "$REPO_ROOT/.env" ]; then
  if grep -q "^COMMIT_SHA=" "$REPO_ROOT/.env"; then
    sed -i "s/^COMMIT_SHA=.*/COMMIT_SHA=$COMMIT_SHA/" "$REPO_ROOT/.env"
  else
    echo "COMMIT_SHA=$COMMIT_SHA" >> "$REPO_ROOT/.env"
  fi
fi

echo "Pre-commit checks... (commit: $COMMIT_SHA)"

echo "  [1/8] Backend lint..."
cd "$REPO_ROOT"
deno task lint

echo "  [2/8] Backend type-check..."
deno task check

echo "  [3/8] Backend unit tests..."
deno task test

echo "  [4/8] Frontend lint (all files)..."
cd "$REPO_ROOT/frontend"
deno run -A npm:@biomejs/biome check src/

echo "  [5/8] Frontend type-check (all files)..."
./node_modules/.bin/tsc --noEmit --skipLibCheck

echo "  [6/8] Frontend unit tests..."
./node_modules/.bin/vitest run

echo "  [7/8] Smoke tests (skipped if services offline)..."
cd "$REPO_ROOT"
if curl -sf http://localhost:5000/health >/dev/null 2>&1 && curl -sf http://localhost:5018/health >/dev/null 2>&1; then
  deno task test:smoke
else
  echo "       Services not fully running — skipping smoke tests."
fi

echo "  [8/8] Integration tests (skipped if services offline)..."
if curl -sf http://localhost:5000/health >/dev/null 2>&1 && curl -sf http://localhost:5032/health >/dev/null 2>&1; then
  deno task test:integration
else
  echo "       Services not fully running — skipping integration tests."
fi

echo "Pre-commit checks passed."

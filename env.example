# Copy this to .env and fill in values before running in production.
# For local dev (devcontainer) the defaults in compose.yml are sufficient.
#
# NOTE: named "env.example" (no dot prefix) intentionally — Deno's dotenv loader
# auto-validates ".env.example" as a required-vars manifest and would fail startup
# for any service that doesn't have all listed vars present.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Set a strong password for homelab / Fly.io deployments.
# The devcontainer uses its own internal postgres (not these vars).
POSTGRES_USER=veta
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=veta

# ── Git / build metadata ──────────────────────────────────────────────────────
COMMIT_SHA=dev

# ── Domain (homelab / Fly.io) ─────────────────────────────────────────────────
# Used by Traefik for TLS cert provisioning and routing.
# DOMAIN=veta.home
# ACME_EMAIL=you@example.com

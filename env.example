# Copy this to .env and fill in values before running in production.
# For local dev (devcontainer) the defaults in compose.yml are sufficient.
#
# NOTE: named "env.example" (no dot prefix) intentionally — Deno's dotenv loader
# auto-validates ".env.example" as a required-vars manifest and would fail startup
# for any service that doesn't have all listed vars present.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Set a strong password for homelab / Fly.io deployments.
# The devcontainer uses its own internal postgres (not these vars).
POSTGRES_USER=veta
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=veta

# ── Git / build metadata ──────────────────────────────────────────────────────
COMMIT_SHA=dev

# ── OAuth2 login controls ─────────────────────────────────────────────────────
# Shared passcode used by /oauth/authorize and /oauth/register.
# Set this to a strong value in production.
OAUTH2_SHARED_SECRET=veta-dev-passcode
# Optional per-user overrides: userId:secret;userId2:secret2
# OAUTH2_USER_SECRETS=alice:alice-secret;admin:admin-secret
# Optional client list format: clientId:redirect1,redirect2|scope1,scope2
# OAUTH2_CLIENTS=veta-web:postmessage|openid,profile;veta-automation:postmessage|openid,profile

# ── Domain (homelab / Fly.io) ─────────────────────────────────────────────────
# Used by Traefik for TLS cert provisioning and routing.
# DOMAIN=veta.home
# ACME_EMAIL=you@example.com

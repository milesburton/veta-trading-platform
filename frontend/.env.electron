# Environment variables baked into the renderer at build time for packaged Electron.
# All services run on localhost with their standard ports.
# Vite loads this file when --mode electron is passed.

VITE_DEPLOYMENT=electron

# Gateway (single entry point for all API + WS)
VITE_GATEWAY_URL=http://localhost:5011
VITE_GATEWAY_WS_URL=ws://localhost:5011/ws

# Individual service health check URLs (used by ServicesPanel)
VITE_MARKET_HTTP_URL=http://localhost:5000
VITE_EMS_URL=http://localhost:5001
VITE_OMS_URL=http://localhost:5002
VITE_LIMIT_URL=http://localhost:5003
VITE_TWAP_URL=http://localhost:5004
VITE_POV_URL=http://localhost:5005
VITE_VWAP_URL=http://localhost:5006
VITE_ICEBERG_URL=http://localhost:5021
VITE_SNIPER_URL=http://localhost:5022
VITE_AP_URL=http://localhost:5023
VITE_IS_URL=http://localhost:5026
VITE_MOMENTUM_URL=http://localhost:5025
VITE_OBSERVABILITY_URL=http://localhost:5007
VITE_USER_SERVICE_URL=http://localhost:5008
VITE_JOURNAL_URL=http://localhost:5009
VITE_FIX_ARCHIVE_URL=http://localhost:5012
VITE_NEWS_AGGREGATOR_URL=http://localhost:5013
VITE_FIX_GW_URL=http://localhost:9881
VITE_ANALYTICS_URL=http://localhost:5014
VITE_MARKET_DATA_URL=http://localhost:5015
VITE_FEATURE_ENGINE_URL=http://localhost:5017
VITE_SIGNAL_ENGINE_URL=http://localhost:5018
VITE_RECOMMENDATION_URL=http://localhost:5019
VITE_SCENARIO_URL=http://localhost:5020
VITE_LLM_ADVISORY_URL=http://localhost:5024

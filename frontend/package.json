{
  "name": "veta-trading-platform",
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "deno run -A npm:@biomejs/biome check src/",
    "lint:fix": "deno run -A npm:@biomejs/biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test:unit": "NODE_OPTIONS=--max-old-space-size=4096 vitest",
    "test:ui": "npx playwright test",
    "test:ui:headed": "npx playwright test --headed",
    "electron:dev": "ELECTRON_BUILD=1 vite --mode electron",
    "electron:build": "tsc && ELECTRON_BUILD=1 vite build --mode electron && electron-builder --dir",
    "test:electron": "npx playwright test --config=playwright.electron.config.ts",
    "prepare": "cd .. && ./frontend/node_modules/.bin/husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "deno run -A npm:@biomejs/biome check --write",
      "bash -c './node_modules/.bin/tsc --noEmit --skipLibCheck --project tsconfig.json'"
    ]
  },
  "build": {
    "appId": "com.veta.trading-platform",
    "productName": "VETA Trading Platform",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "protocols": [
      { "name": "VETA Trading Platform", "schemes": ["veta"] }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [{ "target": "dmg", "arch": ["universal"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Finance"
    }
  },
  "dependencies": {
    "@preact/signals-react": "^3.9.0",
    "@reduxjs/toolkit": "^2.11.2",
    "flexlayout-react": "^0.8.18",
    "lightweight-charts": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.2",
    "react-hotkeys-hook": "^5.2.4",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.7.0",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@preact/signals-react-transform": "^0.8.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.6",
    "@types/react-window": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^15.2.10",
    "playwright": "^1.40.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}
